# ================================================
  # iaNanoLeads — Variables d'environnement
  # Copier ce fichier en .env et remplir les valeurs
  # NE JAMAIS committer le fichier .env
  # ================================================

  # --- Supabase ---
  SUPABASE_URL=https://your-project.supabase.co
  SUPABASE_ANON_KEY=your_anon_key_here
  SUPABASE_SERVICE_KEY=your_service_role_key_here

  # --- NewsAPI ---
  NEWSAPI_KEY=your_newsapi_key_here

  # --- Cloudflare R2 ---
  R2_ACCOUNT_ID=your_account_id
  R2_ACCESS_KEY_ID=your_access_key_id
  R2_SECRET_ACCESS_KEY=your_secret_access_key
  R2_BUCKET_NAME=iananoleads-storage
  R2_PUBLIC_URL=https://medias.w2k-digital.com

  # --- Serveur ---
  PORT=3000
  NODE_ENV=production
  FRONTEND_URL=https://www.iananoleads.com

  # --- Contact ---
  SUPPORT_EMAIL=support@iananoleads.com
  COMPANY_EMAIL=contact@w2k-digital.com

  # --- FineoPay (à configurer) ---
  FINEOPAY_PUBLIC_KEY=your_fineopay_public_key
  FINEOPAY_WEBHOOK_SECRET=your_webhook_secret
